{
  "version": 2,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version, Authorization" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/invoices", "destination": "/index.html" },
    { "source": "/invoice-use-cases", "destination": "/invoice-use-cases-Invoice.html" },
    { "source": "/invoice-how-it-works", "destination": "/invoice-how-it-works-Invoice.html" },
    { "source": "/tool-Invoice", "destination": "/tool-Invoice.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/refunds", "destination": "/refunds.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/store", "destination": "/store.html" },
    { "source": "/index/General", "destination": "/index-General.html" },
    { "source": "/index", "destination": "/index-Invoice.html" },
    { "source": "/invoice/use-cases", "destination": "/invoice-use-cases-Invoice.html" },
    { "source": "/invoice/how-it-works", "destination": "/invoice-how-it-works-Invoice.html" },
    { "source": "/excel-to-invoice", "destination": "/excel-to-invoice-Invoice.html" },
    { "source": "/bulk-invoice-generator", "destination": "/bulk-invoice-generator-Invoice.html" },
    { "source": "/why-csvlink", "destination": "/why-csvlink-Invoice.html" },
    { "source": "/tool/usedtobemain", "destination": "/tool.html" },
    { "source": "/tool", "destination": "/tool-Invoice.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/api-documentation", "destination": "/api-documentation.html" },
    { "source": "/verify", "destination": "/verify.html" },
    { "source": "/cambiar-contrasena", "destination": "/cambiar-contrasena.html" },
    { "source": "/reset-password", "destination": "/reset-password.html" }
  ]
}
